{
  "name": "raven",
  "version": "2.3.8",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:proxy": "bun run --filter '@raven/proxy' dev",
    "dev:dashboard": "bun run --filter dashboard dev",
    "start": "bun run build && bun run --filter '*' start",
    "start:proxy": "bun run --filter '@raven/proxy' start",
    "start:dashboard": "bun run --filter dashboard start",
    "build": "bun run --filter dashboard build",
    "test": "bun run --filter '@raven/proxy' test",
    "test:all": "bun run --filter '*' test",
    "test:l2": "bun run --filter @raven/proxy test:l2",
    "test:root": "bunx --bun vitest run",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:e2e:full": "RAVEN_E2E_FULL=1 bun run scripts/run-e2e.ts",
    "capture-goldens": "bun run scripts/capture-goldens.ts",
    "test:perf": "bun run --filter '@raven/proxy' test:perf",
    "gate:security": "bun run scripts/gate-security.ts",
    "gate:arch": "depcruise --config dependency-cruiser.config.cjs packages/proxy/src && bun run scripts/check-fetch-boundary.ts && bun run scripts/check-dynamic-delete.ts && bun run scripts/check-ts-expect-error.ts",
    "test:ui": "bun run scripts/run-playwright.ts",
    "prepare": "husky",
    "release": "bun run scripts/release.ts"
  },
  "lint-staged": {
    "packages/{proxy,dashboard}/{src,test}/**/*.{ts,tsx,js,jsx}": "biome check --no-errors-on-unmatched --error-on-warnings --max-diagnostics=500"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "^1.3.11",
    "dependency-cruiser": "18.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "6.0.3"
  },
  "overrides": {
    "flatted": ">=3.4.2",
    "brace-expansion": ">=5.0.5",
    "vite": "8.1.4",
    "postcss": ">=8.5.10",
    "@babel/core": ">=7.29.6",
    "undici": "^7.28.0"
  },
  "dependencies": {
    "hono": "4.12.29",
    "micromatch": "^4.0.8",
    "next": "16.2.10",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
